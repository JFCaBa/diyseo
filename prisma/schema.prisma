generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String        @id @default(cuid())
  ownerId   String        @unique
  name      String        @default("My Workspace")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sites     SiteProject[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  workspace     Workspace?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SiteProject {
  id           String       @id @default(cuid())
  workspaceId  String
  name         String
  domain       String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandProfile BrandProfile?
  articles     Article[]
  keywords     Keyword[]
}

model BrandProfile {
  id                      String      @id @default(cuid())
  siteProjectId           String      @unique
  contentLanguage         String?
  businessType            String?
  brandVoiceTone          String?
  targetAudience          String?
  serviceArea             String?
  topicsToAvoid           String?
  keyThemes               String?
  customImageInstructions String?
  imageStyle              String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  siteProject             SiteProject @relation(fields: [siteProjectId], references: [id], onDelete: Cascade)
}

model Article {
  id            String        @id @default(cuid())
  title         String
  slug          String
  excerpt       String?
  contentHtml   String
  seoTitle      String?
  seoDescription String?
  status        ArticleStatus @default(DRAFT)
  publishedAt   DateTime?
  siteProjectId String
  keywordId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  siteProject   SiteProject   @relation(fields: [siteProjectId], references: [id], onDelete: Cascade)
  keyword       Keyword?      @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@unique([siteProjectId, slug])
  @@index([siteProjectId, status, publishedAt])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

model Keyword {
  id            String        @id @default(cuid())
  siteProjectId String
  term          String
  status        KeywordStatus @default(NEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  siteProject   SiteProject   @relation(fields: [siteProjectId], references: [id], onDelete: Cascade)
  articles      Article[]

  @@unique([siteProjectId, term])
}

enum KeywordStatus {
  NEW
  USED
}
